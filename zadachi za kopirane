using System;
using System.Collections.Generic;
using System.Linq;

class Program
{
    static void Main()
    {
        List<int> times = Console.ReadLine().Split().Select(int.Parse).ToList();
        int middle = times.Count / 2;
        
        double leftTime = 0;
        double rightTime = 0;
        
        for (int i = 0; i < middle; i++)
        {
            leftTime += times[i];
            if (times[i] == 0)
            {
                leftTime *= 0.8;
            }
        }
        
        for (int i = times.Count - 1; i > middle; i--)
        {
            rightTime += times[i];
            if (times[i] == 0)
            {
                rightTime *= 0.8;
            }
        }
        
        if (leftTime < rightTime)
        {
            Console.WriteLine($"The winner is left with total time: {leftTime:F1}");
        }
        else
        {
            Console.WriteLine($"The winner is right with total time: {rightTime:F1}");
        }
    }
}